<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>AllSolve | One Device. Every Answer.</title>
  <!-- Google Fonts & Simple Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #0A0A0F;
      color: #F0F0F5;
      scroll-behavior: smooth;
    }

    /* premium dark/glass style */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 32px;
    }

    /* header & nav */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      flex-wrap: wrap;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #FFFFFF, #A0D8FF);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .logo span {
      background: none;
      color: #fff;
      font-weight: 600;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      align-items: center;
      flex-wrap: wrap;
    }
    .nav-links a {
      color: #DDD;
      text-decoration: none;
      font-weight: 500;
      transition: 0.2s;
    }
    .nav-links a:hover {
      color: #7AC8FF;
    }
    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    .search-wrapper input {
      background: rgba(20,20,30,0.9);
      border: 1px solid #2C2C3A;
      border-radius: 40px;
      padding: 8px 16px 8px 40px;
      color: white;
      font-size: 0.9rem;
      width: 200px;
      transition: 0.2s;
    }
    .search-wrapper input:focus {
      outline: none;
      border-color: #7AC8FF;
      width: 260px;
    }
    .search-wrapper i {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #888;
      font-size: 0.9rem;
    }
    .btn-outline-light {
      border: 1px solid #7AC8FF;
      background: transparent;
      padding: 8px 20px;
      border-radius: 40px;
      color: #7AC8FF;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
    }
    .btn-outline-light:hover {
      background: #7AC8FF20;
    }

    /* buttons */
    .btn-primary {
      background: #7AC8FF;
      border: none;
      padding: 14px 32px;
      border-radius: 48px;
      font-weight: 700;
      font-size: 1rem;
      color: #0A0A0F;
      cursor: pointer;
      transition: 0.2s;
      display: inline-block;
      text-decoration: none;
    }
    .btn-primary:hover {
      background: #5bb0e6;
      transform: translateY(-2px);
    }
    .btn-secondary {
      background: transparent;
      border: 1px solid #7AC8FF;
      padding: 14px 32px;
      border-radius: 48px;
      font-weight: 600;
      color: #7AC8FF;
      cursor: pointer;
      transition: 0.2s;
    }

    /* hero */
    .hero {
      padding: 80px 0 60px;
      text-align: center;
    }
    .hero h1 {
      font-size: 3.5rem;
      font-weight: 800;
      line-height: 1.2;
      background: linear-gradient(145deg, #FFFFFF, #9ACDFF);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 20px;
    }
    .hero p {
      font-size: 1.3rem;
      color: #BBB;
      max-width: 700px;
      margin: 0 auto 32px;
    }
    .hero-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* cards grid */
    .section-title {
      font-size: 2.2rem;
      font-weight: 700;
      margin: 60px 0 32px 0;
      text-align: center;
    }
    .card-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 32px;
      justify-content: center;
    }
    .watch-card {
      background: #111118;
      border-radius: 48px;
      padding: 32px 24px;
      width: 300px;
      text-align: center;
      border: 1px solid #22222C;
      transition: 0.25s;
    }
    .watch-card:hover {
      border-color: #7AC8FF;
      transform: translateY(-8px);
    }
    .watch-icon {
      font-size: 3.5rem;
      color: #7AC8FF;
      margin-bottom: 20px;
    }
    .watch-card h3 {
      font-size: 1.8rem;
      margin-bottom: 12px;
    }
    .price {
      font-size: 1.6rem;
      font-weight: 800;
      margin: 16px 0;
      color: #7AC8FF;
    }
    .feature-list {
      text-align: left;
      margin: 20px 0;
      list-style: none;
    }
    .feature-list li {
      margin: 10px 0;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .feature-list i {
      width: 20px;
      color: #7AC8FF;
    }

    /* features grid */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      margin: 40px 0;
    }
    .feature-item {
      background: #0F0F16;
      padding: 28px;
      border-radius: 32px;
      border-left: 4px solid #7AC8FF;
    }
    .feature-item i {
      font-size: 2rem;
      margin-bottom: 16px;
      color: #7AC8FF;
    }
    .feature-item h4 {
      font-size: 1.4rem;
      margin-bottom: 12px;
    }

    /* compare table */
    .compare-table {
      background: #0B0B12;
      border-radius: 48px;
      overflow-x: auto;
      margin: 40px 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    th, td {
      padding: 18px 20px;
      border-bottom: 1px solid #222;
    }
    th {
      color: #7AC8FF;
      font-weight: 600;
    }
    tr:last-child td {
      border-bottom: none;
    }

    /* footer */
    footer {
      margin-top: 80px;
      border-top: 1px solid #1E1E28;
      padding: 48px 0 32px;
      text-align: center;
      color: #888;
    }

    /* modal search results */
    .search-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.9);
      backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      visibility: hidden;
      opacity: 0;
      transition: 0.2s;
    }
    .search-modal.active {
      visibility: visible;
      opacity: 1;
    }
    .modal-content {
      background: #111118;
      max-width: 600px;
      width: 90%;
      border-radius: 48px;
      padding: 32px;
      border: 1px solid #2C2C3A;
    }
    .close-modal {
      float: right;
      font-size: 1.5rem;
      cursor: pointer;
    }

    @media (max-width: 768px) {
      .navbar {
        flex-direction: column;
        gap: 16px;
      }
      .hero h1 {
        font-size: 2.2rem;
      }
      .container {
        padding: 0 20px;
      }
    }
  </style>
</head>
<body>

<div class="search-modal" id="searchModal">
  <div class="modal-content">
    <i class="fas fa-times close-modal" style="float:right; cursor:pointer;"></i>
    <h3 style="margin-bottom: 20px;">🔍 Search Results</h3>
    <div id="searchResultsList">
      <p>Type something like "solar", "emergency", "pro", "elite"</p>
    </div>
  </div>
</div>

<header>
  <div class="container">
    <div class="navbar">
      <div class="logo">AllSolve<span>.</span></div>
      <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#features">Features</a>
        <a href="#products">Products</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <div class="search-wrapper">
          <i class="fas fa-search"></i>
          <input type="text" id="globalSearchInput" placeholder="Search solar, SOS, AI...">
        </div>
        <button class="btn-outline-light" id="shopBtn">Shop</button>
      </div>
    </div>
  </div>
</header>

<main>
  <!-- Hero Section -->
  <section id="home">
    <div class="container hero">
      <h1>The future doesn’t need a plug.</h1>
      <p>Solar-powered · AI Guardian · Emergency SOS · Tamper-proof · AllSolve merges autonomy with intelligence. One device, every answer.</p>
      <div class="hero-buttons">
        <a href="#products" class="btn-primary">Explore the Trinity</a>
        <button class="btn-secondary" id="watchFilmBtn">Watch the Film</button>
      </div>
    </div>
  </section>

  <!-- Products Section (3 models) -->
  <section id="products">
    <div class="container">
      <h2 class="section-title">⚡ The Trinity — Three Paths. One Mission.</h2>
      <div class="card-grid">
        <!-- Sport -->
        <div class="watch-card">
          <div class="watch-icon"><i class="fas fa-running"></i></div>
          <h3>AllSolve Sport</h3>
          <div class="price">$59</div>
          <ul class="feature-list">
            <li><i class="fas fa-sun"></i> SolarBoost Loop strap</li>
            <li><i class="fas fa-heartbeat"></i> Muscle oxygen mapping</li>
            <li><i class="fas fa-shield-alt"></i> Impact Shield graphene</li>
            <li><i class="fas fa-map-marked-alt"></i> Dual-band GPS</li>
          </ul>
          <button class="btn-secondary" style="width:100%">Pre-order</button>
        </div>
        <!-- Pro -->
        <div class="watch-card">
          <div class="watch-icon"><i class="fas fa-briefcase"></i></div>
          <h3>AllSolve Pro</h3>
          <div class="price">$79</div>
          <ul class="feature-list">
            <li><i class="fas fa-projector"></i> Holo-Assistant AR display</li>
            <li><i class="fas fa-satellite-dish"></i> Satellite SOS relay</li>
            <li><i class="fas fa-battery-full"></i> 10d battery (Solar +5d)</li>
            <li><i class="fas fa-microphone-alt"></i> Offline Voice AI</li>
          </ul>
          <button class="btn-secondary" style="width:100%">Pre-order</button>
        </div>
        <!-- Elite -->
        <div class="watch-card">
          <div class="watch-icon"><i class="fas fa-gem"></i></div>
          <h3>AllSolve Elite</h3>
          <div class="price">$ 99</div>
          <ul class="feature-list">
            <li><i class="fas fa-lock"></i> Hardware Privacy Switch</li>
            <li><i class="fas fa-id-card"></i> Cardiac Signature Unlock</li>
            <li><i class="fas fa-concierge-bell"></i> 24/7 Concierge AI</li>
            <li><i class="fas fa-thermometer-half"></i> Thermal Regulation</li>
          </ul>
          <button class="btn-secondary" style="width:100%">Pre-order</button>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE REFINEMENT + INNOVATIVE -->
  <section id="features">
    <div class="container">
      <h2 class="section-title">🚀 Beyond Intelligence: AllSolve Core Innovations</h2>
      <div class="features-grid">
        <div class="feature-item"><i class="fas fa-solar-panel"></i><h4>SolarCore™</h4><p>15% charge per hour in direct sun. Up to 10 days total, never fear the outlet again.</p></div>
        <div class="feature-item"><i class="fas fa-ambulance"></i><h4>LifeGuard AI</h4><p>Detects AFib + immobility → automatic emergency call with GPS, vitals & 10s pre-event audio.</p></div>
        <div class="feature-item"><i class="fas fa-fingerprint"></i><h4>Tamper Lockdown</h4><p>Piezo sensors trigger 90dB alarm & lock if removed without service mode. Theft alerts instantly.</p></div>
        <div class="feature-item"><i class="fas fa-microchip"></i><h4>Offline Voice AI</h4><p>On-device neural engine: control music, timers, health metrics even without internet.</p></div>
        <div class="feature-item"><i class="fas fa-temperature-low"></i><h4>Thermal Comfort</h4><p>Ceramic backplate gently warms or cools wrist for better sleep & recovery.</p></div>
        <div class="feature-item"><i class="fas fa-uv"></i><h4>UV Exposure Tracker</h4><p>Alerts before sunburn, cumulative lifetime UV monitoring.</p></div>
        <div class="feature-item"><i class="fas fa-car-key"></i><h4>Digital Key Vault</h4><p>NFC car keys, hotel keys, ID — military-grade encrypted.</p></div>
        <div class="feature-item"><i class="fas fa-waveform"></i><h4>SpiroSense™</h4><p>Early detection of asthma/panic attacks via breath analysis + guided exercises.</p></div>
        <div class="feature-item"><i class="fas fa-charging-station"></i><h4>Sonar Phone Finder</h4><p>High-frequency pulse locates lost phone within 20 meters.</p></div>
      </div>
    </div>
  </section>

  <!-- Compare models & additional spec -->
  <div class="container">
    <h2 class="section-title">⚙️ Compare Every Detail</h2>
    <div class="compare-table">
      <table>
        <thead>
          <tr><th>Feature</th><th>Sport</th><th>Pro</th><th>Elite</th></tr>
        </thead>
        <tbody>
          <tr><td>Solar charging</td><td>✅ SolarBoost strap</td><td>✅ Photovoltaic layer</td><td>✅ Gold-infused solar crystal</td></tr>
          <tr><td>Battery life</td><td>7d (10d solar)</td><td>10d (15d solar)</td><td>12d (18d solar)</td></tr>
          <tr><td>Emergency SOS</td><td>Auto call + vitals</td><td>Satellite + cellular</td><td>Priority concierge dispatch</td></tr>
          <tr><td>Tamper detection</td><td>✅ Alarm + lock</td><td>✅ + GPS tracking</td><td>✅ + self-destruct data option</td></tr>
          <tr><td>AI assistant</td><td>Online/Offline basic</td><td>Advanced offline + Holo</td><td>24/7 Human + AI concierge</td></tr>
          <tr><td>Material</td><td>Carbon fiber</td><td>Titanium + Sapphire</td><td>Ceramic + 24k gold accents</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- About Section -->
  <section id="about">
    <div class="container">
      <h2 class="section-title">🧠 About AllSolve</h2>
      <div style="background:#0F0F18; border-radius: 48px; padding: 48px; text-align: center; margin-bottom: 40px;">
        <p style="font-size:1.2rem; max-width:800px; margin:0 auto; color:#CCC">We started AllSolve because wearables gave us anxiety—not freedom. <br><br> 
        Engineers from NASA JPL, EMTs, and privacy architects united to build the first smartwatch that charges with the sun, calls for help when you can’t, and guards your data with hardware switches. <strong>One device, every answer.</strong></p>
        <div style="margin-top: 32px;"><i class="fas fa-leaf" style="color:#7AC8FF"></i> Carbon Negative by 2027 &nbsp;&nbsp;|&nbsp;&nbsp; <i class="fas fa-shield-hooded"></i> Right to Repair program</div>
      </div>
    </div>
  </section>

  <!-- Contact + Newsletter -->
  <section id="contact">
    <div class="container">
      <h2 class="section-title">📡 Stay connected</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 40px; justify-content: space-between; background:#0B0B12; border-radius: 48px; padding: 40px;">
        <div style="flex:1">
          <h3>24/7 AI Support</h3>
          <p>Press & hold the side button — our neural assistant answers any question, even offline.</p>
          <p><i class="fas fa-envelope"></i> hello@allsolve.com</p>
          <p><i class="fas fa-headset"></i> Priority line for Elite members</p>
        </div>
        <div style="flex:1">
          <h3>Get early access</h3>
          <input type="email" placeholder="Your email" id="newsEmail" style="background:#1E1E2A; border:1px solid #333; padding:12px; border-radius: 40px; width:100%; margin-bottom:16px; color:white;">
          <button id="subscribeBtn" class="btn-primary" style="width:100%">Subscribe →</button>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <div class="container">
    <div class="logo" style="margin-bottom:20px;">AllSolve<span>.</span></div>
    <div style="display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; margin-bottom: 24px;">
      <a href="#" style="color:#AAA; text-decoration: none;">Privacy</a>
      <a href="#" style="color:#AAA; text-decoration: none;">Terms</a>
      <a href="#" style="color:#AAA; text-decoration: none;">Press</a>
      <a href="#" style="color:#AAA; text-decoration: none;">Service centers</a>
    </div>
    <div style="font-size: 0.85rem;">© 2026 AllSolve — Solar autonomy meets lifesaving intelligence. One Device. Every Answer.</div>
  </div>
</footer>

<script>
  // Interactive search that looks through page content: models, features, keywords
  const searchInput = document.getElementById('globalSearchInput');
  const modal = document.getElementById('searchModal');
  const resultsContainer = document.getElementById('searchResultsList');
  const closeModalBtn = document.querySelector('.close-modal');

  // Content database for search
  const searchableContent = [
    { title: "AllSolve Sport", desc: "Carbon fiber, SolarBoost strap, Impact Shield, $449, GPS, muscle oxygen", category: "product" },
    { title: "AllSolve Pro", desc: "Titanium, Holo-Assistant AR, Satellite SOS, 10-day battery, Offline AI", category: "product" },
    { title: "AllSolve Elite", desc: "Ceramic, Privacy Switch, Cardiac Unlock, Thermal Regulation, Concierge AI, $1499", category: "product" },
    { title: "SolarCore", desc: "Solar-powered battery, 15% per hour sunlight, up to 10-18 days total", category: "feature" },
    { title: "Emergency health detection", desc: "AFib monitoring, automatic emergency calling with vitals and GPS, fall detection", category: "feature" },
    { title: "Tamper detection", desc: "Alerts if someone tries to break it, 90dB alarm, theft alert, service mode lock", category: "feature" },
    { title: "Advanced AI assistant", desc: "24/7 support button, offline voice, Holo-Assistant on Pro, concierge on Elite", category: "feature" },
    { title: "GPS tracking", desc: "Dual-band GPS, satellite relay for emergencies", category: "feature" },
    { title: "SpiroSense", desc: "Breathing analysis for asthma, panic attacks, guided exercises", category: "feature" },
    { title: "Thermal Regulation", desc: "Wrist warming/cooling for comfort and sleep", category: "feature" },
    { title: "UV Exposure Tracker", desc: "Sunburn warnings, cumulative UV monitoring", category: "feature" },
    { title: "Digital Key Vault", desc: "NFC car keys, hotel keys, ID, encrypted storage", category: "feature" },
    { title: "Sonar phone finder", desc: "Find lost phone via high-frequency pulse", category: "feature" },
    { title: "Offline Voice AI", desc: "Works without internet, on-device processing", category: "feature" }
  ];

  function performSearch(query) {
    if (!query.trim()) {
      resultsContainer.innerHTML = "<p>✨ Try: solar, emergency, pro, elite, tamper, SOS</p>";
      return;
    }
    const lowerQuery = query.toLowerCase();
    const filtered = searchableContent.filter(item => 
      item.title.toLowerCase().includes(lowerQuery) || 
      item.desc.toLowerCase().includes(lowerQuery)
    );
    if (filtered.length === 0) {
      resultsContainer.innerHTML = `<p>🔍 No results for "${query}". Try "solar" or "emergency call".</p>`;
      return;
    }
    let html = `<ul style="list-style:none;">`;
    filtered.forEach(item => {
      html += `<li style="margin-bottom: 16px; border-bottom:1px solid #2C2C3A; padding-bottom:12px;">
                <strong style="color:#7AC8FF;">${item.title}</strong><br>
                <span style="font-size:0.85rem;">${item.desc}</span><br>
                <small style="color:#7AC8FF;">${item.category}</small>
              </li>`;
    });
    html += `</ul>`;
    resultsContainer.innerHTML = html;
  }

  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      performSearch(searchInput.value);
      modal.classList.add('active');
    }
  });
  // optional: search icon trigger
  document.querySelector('.search-wrapper i').addEventListener('click', () => {
    performSearch(searchInput.value);
    modal.classList.add('active');
  });
  closeModalBtn.addEventListener('click', () => modal.classList.remove('active'));
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.remove('active');
  });

  // Shop button scroll to products
  document.getElementById('shopBtn').addEventListener('click', () => {
    document.getElementById('products').scrollIntoView({ behavior: 'smooth' });
  });
  document.getElementById('watchFilmBtn').addEventListener('click', () => {
    alert("🎬 AllSolve concept film: The Unplugged Challenge. Coming this summer. Stay tuned.");
  });
  // subscribe
  document.getElementById('subscribeBtn').addEventListener('click', () => {
    const email = document.getElementById('newsEmail').value;
    if(email && email.includes('@')) alert(`✅ Thanks! We'll notify about AllSolve launch at ${email}`);
    else alert("Please enter a valid email for exclusive updates.");
  });
  // pre-order buttons generic demo
  const preorderBtns = document.querySelectorAll('.watch-card .btn-secondary');
  preorderBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const card = e.target.closest('.watch-card');
      const modelName = card.querySelector('h3').innerText;
      alert(`🚀 ${modelName} pre-order reservation opens June 2026. You'll be first to know.`);
    });
  });
</script>
</body>
</html>
